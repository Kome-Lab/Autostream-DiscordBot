SERVICE_ID=discord-bot-01
SERVICE_NAME=Discord Bot
SERVICE_PUBLIC_URL=https://discord-bot.example.com
SERVICE_VERSION=dev
AUTOSTREAM_ENV=production
AUTOSTREAM_REQUIRE_CONTROL_PANEL_RUNTIME_CONFIG=true

CONTROL_PANEL_URL=https://control.example.com
CONTROL_PANEL_TOKEN=<SERVICE_TOKEN>
CONTROL_PANEL_HEARTBEAT_INTERVAL_SEC=30
SERVICE_CONTROL_TOKEN_SHA256=<SHA256_OF_CONTROL_PANEL_TO_SERVICE_TOKEN>

WORKER_URL=https://worker.example.com
WORKER_TOKEN=<CONTROL_PANEL_TO_SERVICE_TOKEN>
WORKER_EVENT_TIMEOUT_SEC=3

ENCODER_AUDIO_TIMEOUT_SEC=5
ENCODER_AUDIO_RETRY_MAX=3
ENCODER_AUDIO_RETRY_BASE_DELAY_SEC=1
DISCORD_RECONNECT_ENABLED=true
DISCORD_RECONNECT_MAX_ATTEMPTS=5
DISCORD_RECONNECT_BASE_DELAY=2s
DISCORD_RECONNECT_MAX_DELAY=30s

AUTOSTREAM_BIND_ADDR=127.0.0.1:8080
TZ=Asia/Tokyo

# Normally managed by Control Panel Discord Bot Config.
# DISCORD_BOT_TOKEN=<DISCORD_BOT_TOKEN>

# Prefer stream-scoped ingest tokens from Control Panel. Static token is fallback only.
# ENCODER_AUDIO_TOKEN=<DISCORD_BOT_TO_ENCODER_AUDIO_TOKEN>
